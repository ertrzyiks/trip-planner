---
import 'maplibre-gl/dist/maplibre-gl.css';
import { getCollection, render } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import allPlaces from '../data/places.json';
import { getPlaceDescriptionMap, normalizePlaceKey } from '../utils/place-descriptions';

const pageTitle = 'Operation Overlord';
const phaseOrder = [
  'Neptune Beaches',
  'Airborne Landings',
  'Cotentin Drive',
  'Caen Front',
  'Bocage Breakout',
  'Mortain Counterattack',
  'Falaise Encirclement',
] as const;

const overlordPlaces = allPlaces
  .filter((place) =>
    place.tags.includes('Operation Overlord') && !place.tags.includes('Epilogue')
  )
  .sort((a, b) => {
    const aIndex = phaseOrder.findIndex((phase) => a.tags.includes(phase));
    const bIndex = phaseOrder.findIndex((phase) => b.tags.includes(phase));
    return (aIndex === -1 ? 999 : aIndex) - (bIndex === -1 ? 999 : bIndex);
  });

const placeDescriptions = getPlaceDescriptionMap();
const placeEntries = await getCollection('places');
const renderedPlaceContent = await Promise.all(
  placeEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return {
      name: entry.data.name,
      slug: entry.id,
      Content,
    };
  }),
);

const overlordPlacesWithDescriptions = overlordPlaces.map((place) => ({
  ...place,
  description:
    placeDescriptions.get(normalizePlaceKey(place.name)) ??
    'No description is available for this location yet.',
}));
---

<MainLayout title={pageTitle} activePage="overlord">
  <section class="layout">
    <section class="panel">
      <div id="panel-default">
        <p class="eyebrow">Operation Study</p>
        <h1>{pageTitle}</h1>
        <p class="intro">
          This view follows the campaign from the beachheads into the Normandy
          interior, tracking how the Allied armies shifted from landing to breakout
          and encirclement.
        </p>

        <section class="insight">
          <h2>Movement In Broad Strokes</h2>
          <p>
            The U.S. First Army landed at Utah and Omaha, secured the Cotentin, and
            captured Cherbourg before pushing through Saint-Lo and Avranches during
            Operation Cobra.
          </p>
          <p>
            The British Second Army and Canadian formations fought a sustained battle
            around Caen, tying down German armor and then driving south toward
            Falaise.
          </p>
          <p>
            A German counterattack at Mortain failed, and Allied pressure from north
            and south closed around Argentan and Falaise, collapsing German 7th Army
            positions in Normandy.
          </p>
        </section>

        <section class="timeline">
          <h2>Route Structure</h2>
          <ol>
            <li>Neptune beaches and airborne bridges secure the lodgment.</li>
            <li>Cotentin drive captures Cherbourg to support logistics.</li>
            <li>Caen sector fixes major German armored reserves.</li>
            <li>Saint-Lo and Cobra open the western breakout.</li>
            <li>Mortain fails, then Falaise-Argentan closes the pocket.</li>
          </ol>
        </section>
      </div>

      <div id="panel-selected" class="panel-selected is-hidden" aria-live="polite">
        <p class="eyebrow">Selected Place</p>
        <h2 id="selected-place-name">Place name</h2>
        <div id="selected-place-body" class="place-body"></div>
        <button id="show-overview" type="button" class="overview-button">
          Back To Campaign Overview
        </button>
      </div>
    </section>

    <section class="map-shell">
      <div id="map" class="map"></div>
    </section>
  </section>

  <section id="place-content-cache" class="content-cache" aria-hidden="true">
    {
      renderedPlaceContent.map((entry) => (
        <article data-place-content={entry.name} data-place-slug={entry.slug}>
          <entry.Content />
        </article>
      ))
    }
  </section>

  <script define:vars={{ places: overlordPlacesWithDescriptions }}>
    window.__TRIP_PLACES__ = places;
  </script>
  <script is:inline>
    const normalizePlaceKey = (value) =>
      value
        .toLowerCase()
        .normalize('NFKD')
        .replace(/[^\p{L}\p{N}]+/gu, ' ')
        .trim()
        .replace(/\s+/g, ' ');

    const placeContentMap = {};
    const contentNodes = document.querySelectorAll('#place-content-cache [data-place-content]');
    contentNodes.forEach((node) => {
      const name = node.getAttribute('data-place-content') || '';
      const slug = node.getAttribute('data-place-slug') || '';
      const html = node.innerHTML.trim();

      if (name && html) {
        placeContentMap[normalizePlaceKey(name)] = html;
      }

      if (slug && html) {
        placeContentMap[normalizePlaceKey(slug.replace(/[-_]/g, ' '))] = html;
      }
    });

    window.__TRIP_PLACE_CONTENT__ = placeContentMap;
  </script>
  <script>
    import '../scripts/normandy-map.ts';
  </script>
</MainLayout>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(280px, 400px) minmax(0, 1fr);
    gap: 1.25rem;
  }

  .panel,
  .map-shell {
    border: 1px solid var(--outline);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 18px 50px rgba(16, 36, 63, 0.12);
  }

  .panel {
    padding: 1.5rem;
    background: var(--panel);
    backdrop-filter: blur(12px);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--accent-dark);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.1rem, 4.4vw, 4rem);
    line-height: 0.95;
  }

  .intro {
    margin: 1rem 0 1.25rem;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.55;
  }

  .panel-selected h2 {
    margin: 0;
    font-size: clamp(1.5rem, 3.2vw, 2.1rem);
  }

  .panel-selected {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 100%;
  }

  .place-body {
    overflow: auto;
    max-height: clamp(280px, 58vh, 68vh);
    padding-right: 0.35rem;
  }

  .place-body p {
    margin: 0.35rem 0;
    color: var(--muted);
    line-height: 1.4;
    font-size: 0.92rem;
  }

  .overview-button {
    margin-top: auto;
    border: 1px solid rgba(183, 77, 44, 0.45);
    background: rgba(183, 77, 44, 0.15);
    color: var(--ink);
    border-radius: 999px;
    padding: 0.55rem 0.85rem;
    cursor: pointer;
    width: fit-content;
    font-family: inherit;
  }

  .is-hidden {
    display: none;
  }

  .content-cache {
    display: none;
  }

  .insight h2,
  .timeline h2 {
    margin: 0.3rem 0 0.55rem;
    font-size: 1.05rem;
  }

  .insight p {
    margin: 0 0 0.65rem;
    line-height: 1.45;
    color: var(--muted);
  }

  .timeline {
    margin-top: 1rem;
    border-top: 1px solid var(--outline);
    padding-top: 0.85rem;
  }

  .timeline ol {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .map-shell {
    position: relative;
    min-height: 70vh;
    background: #d8e3e8;
  }

  .map {
    position: absolute;
    inset: 0;
  }

  :global(.marker) {
    width: 16px;
    height: 16px;
    padding: 0;
    border: 3px solid #fff4e8;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 6px rgba(183, 77, 44, 0.18);
    cursor: pointer;
    transition: transform 120ms ease, background-color 120ms ease;
  }

  :global(.marker.is-selected) {
    width: 24px;
    height: 24px;
    background: #0f6e8c;
    box-shadow: 0 0 0 7px rgba(15, 110, 140, 0.22);
    transform: scale(1.05);
  }

  :global(.maplibregl-popup-content) {
    border-radius: 18px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 12px 36px rgba(16, 36, 63, 0.18);
    font-family: Georgia, 'Times New Roman', serif;
  }

  :global(.popup) {
    padding: 0.95rem 1rem;
    min-width: 220px;
    background: #fffaf2;
  }

  :global(.popup h2) {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
  }

  :global(.popup p) {
    margin: 0 0 0.75rem;
    color: var(--muted);
    font-size: 0.88rem;
  }

  :global(.popup ul) {
    margin: 0;
    padding-left: 1.1rem;
  }

  :global(.popup li) {
    margin: 0.15rem 0;
  }

  @media (max-width: 900px) {
    .layout {
      grid-template-columns: 1fr;
    }

    .map-shell {
      min-height: 60vh;
    }
  }
</style>
